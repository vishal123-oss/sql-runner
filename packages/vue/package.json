{
  "name": "@vsql/vue",
  "version": "0.1.0",
  "description": "Vue components and composables for @vsql/core SQL editor",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@vsql/core": "workspace:*"
  },
  "peerDependencies": {
    "vue": ">=3.3.0"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vue": "^3.5.0"
  },
  "keywords": ["sql", "editor", "vue", "sql-runner", "codemirror"],
  "license": "MIT"
}
