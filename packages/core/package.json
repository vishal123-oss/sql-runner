{
  "name": "@vsql/core",
  "version": "0.1.0",
  "description": "Framework-agnostic SQL editor, validator, and runner powered by CodeMirror 6",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.18.0",
    "@codemirror/commands": "^6.7.0",
    "@codemirror/lang-sql": "^6.8.0",
    "@codemirror/language": "^6.10.0",
    "@codemirror/lint": "^6.8.0",
    "@codemirror/search": "^6.5.0",
    "@codemirror/state": "^6.4.0",
    "@codemirror/view": "^6.35.0",
    "@lezer/highlight": "^1.2.3",
    "codemirror": "^6.0.0",
    "node-sql-parser": "^5.4.0",
    "sql.js": "^1.12.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.1",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "sql",
    "editor",
    "codemirror",
    "sql-runner",
    "sql-validator",
    "autocomplete"
  ],
  "license": "MIT",
  "sideEffects": [
    "*.css"
  ]
}
