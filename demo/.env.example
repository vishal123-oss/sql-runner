# Copy to .env (cp .env.example .env) and set your values.
# Never commit .env with real secrets.

# Base URL of the demo API server (run: cd server && npm install && npm start)
VITE_API_BASE_URL=http://localhost:3001

# Optional: API key if your server requires auth
VITE_API_KEY=

# Use real database via the server (true). Use in-browser SQLite demo (false).
VITE_USE_REMOTE_DB=true
